{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cyberquest-ctf-backend1.onrender.com/api/:path*"
    },
    {
      "source": "/simulation/:path*",
      "destination": "https://cyberquest-ctf-backend1.onrender.com/simulation/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
